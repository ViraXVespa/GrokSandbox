# === Required: Discord application ===
# Create at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Server (guild) where slash commands are registered immediately.
# Right-click server icon → Copy Server ID (enable Developer Mode first).
DISCORD_GUILD_ID=

# Channel where active + recently closed poll embeds are posted/updated.
# Right-click channel → Copy Channel ID
DISCORD_POLLS_CHANNEL_ID=

# === Optional: permissions / safety ===
# Comma-separated Discord role IDs allowed to create/resolve polls from Discord.
# Leave empty to allow only the bot owner / users with Manage Server.
DISCORD_ADMIN_ROLE_IDS=

# Starting balance for new bettors (tokens)
STARTING_BALANCE=10000

# How many recently closed polls to keep visible in the channel
RECENT_CLOSED_LIMIT=8

# Local hub HTTP bind (RuneLite + Discord bot talk to this)
HUB_HOST=127.0.0.1
HUB_PORT=8766

# Shared secret so only your RuneLite client can push poll events.
# Generate any random string, e.g. `python -c "import secrets; print(secrets.token_hex(16))"`
HUB_API_KEY=

# Bot presence status text
BOT_STATUS=ChatBet | /bet /balance
